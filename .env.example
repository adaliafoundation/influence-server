# Game mode: "hybrid" for local dev (no blockchain), "chain" for production
GAME_MODE=hybrid

# JWT secret for auth tokens
JWT_SECRET=change-me-to-a-real-secret

# Server port (default 3001)
PORT=3001

# Log level: error, warn, info, debug
LOG_LEVEL=info

# Set to 1 to allow insecure login (for testing)
# HYBRID_INSECURE_LOGIN=1
# Speed up action durations for testing (seconds). Unset for normal timing.
# MAX_ACTION_SECONDS=10

# Time acceleration factor (game-seconds per real-second, default 24)
# TIME_ACCELERATION=24

# --- Production / chain mode only ---
# STARKNET_PROVIDER=https://starknet-mainnet.infura.io/v3/YOUR_KEY
# STARKNET_RPC_PROVIDER=https://starknet-mainnet.infura.io/v3/YOUR_KEY
# ETHEREUM_PROVIDER=https://mainnet.infura.io/v3/YOUR_KEY

# --- Optional services ---
# AWS_ACCESS_KEY=
# AWS_SECRET_ACCESS_KEY=
# SENDGRID_API_KEY=
# STRIPE_SECRET_KEY=
